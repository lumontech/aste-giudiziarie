# =====================================================
# Aste Giudiziarie — environment file
# Copiare in /opt/aste.giudiziarie/.env e personalizzare
# Permessi: chmod 600, owner aste:aste
# =====================================================

# Chiave per firmare cookie di sessione (32+ caratteri esadecimali)
# Generabile con: openssl rand -hex 32
FLASK_SECRET_KEY=__GENERA_UNA_CHIAVE_LUNGA__

# Credenziali admin per accesso dashboard
ADMIN_USER=stefano

# Hash bcrypt della password. Generabile con:
#   /opt/aste.giudiziarie/.venv/bin/python server.py --hash-password 'MiaPasswordSegreta'
# Incollare la stringa $2b$... qui sotto:
ADMIN_PASSWORD_HASH=$2b$12$...

# Cookie marcato Secure (true se l'accesso è via HTTPS — consigliato dopo certbot)
COOKIE_SECURE=true

# Abilita autenticazione (true in produzione, false solo per debug locale)
AUTH_ENABLED=true

# File risultati scraper (path assoluto)
RESULTS_FILE=/opt/aste.giudiziarie/results.json
BACKUP_FILE=/opt/aste.giudiziarie/results_backup.json
